@using Microsoft.AspNetCore.Http
@{
    var subject = Context.Session.GetString("Subject");
    var semester = Context.Session.GetString("Semester");
    var academicYear = Context.Session.GetString("AcademicYear");
    var department = Context.Session.GetString("Department");
    var faculty = Context.Session.GetString("FacultyName");
}

<div class="page-center">

    <!-- Optional blobs -->
    <div class="blob blob1"></div>
    <div class="blob blob2"></div>
    <div class="blob blob3"></div>

    <div class="glass-card-index">

        <!-- HEADER -->
        <div class="page-title">
            <h2>End Semester Examination Analytics Tool</h2>
            <p>Built by the Department of Information Technology to empower academic insights</p>
        </div>

        <!-- ALERTS -->
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }

        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success">
                @TempData["Message"]
            </div>
        }

        <!-- BUTTON STATE SCRIPT -->
        @if (TempData["Message"] != null)
        {
            <script>
                        window.addEventListener("load", function() {
                            var analyzeBtn = document.getElementById("analyzeBtn");
                            var uploadBtn = document.getElementById("uploadBtn");

                            analyzeBtn.style.pointerEvents = "auto";
                            analyzeBtn.style.opacity = "1";

                            uploadBtn.disabled = true;
                            uploadBtn.style.opacity = "0.6";
                            uploadBtn.innerText = "Files Uploaded";
                        });
            </script>
        }

        <!-- FORM -->
        <form asp-controller="Upload" asp-action="UploadFiles" method="post" enctype="multipart/form-data" autocomplete="off">

            <label>Subject</label>
            <input type="text" name="Subject" value="@subject" placeholder="Enter subject" required />

            <br />

            <label>Semester</label>
            <select name="Semester">
                <option selected="@(semester == "I")">I</option>
                <option selected="@(semester == "II")">II</option>
                <option selected="@(semester == "III")">III</option>
                <option selected="@(semester == "IV")">IV</option>
                <option selected="@(semester == "V")">V</option>
                <option selected="@(semester == "VI")">VI</option>
                <option selected="@(semester == "VII")">VII</option>
                <option selected="@(semester == "VIII")">VIII</option>
            </select>

            <br />

            <label>Academic Year</label>
            <input type="text" name="AcademicYear" value="@academicYear" placeholder="2025-26" required />

            <br />

            <label>Department</label>
            <select name="Department">
                <option selected="@(department == "Electronics and Telecommunication Engg")">Electronics and Telecommunication Engg</option>
                <option selected="@(department == "Information Technology")">Information Technology</option>
                <option selected="@(department == "Computer Engineering")">Computer Engineering</option>
                <option selected="@(department == "Mechanical Engineering")">Mechanical Engineering</option>
                <option selected="@(department == "Computer Science and Engineering (Data Science)")">Computer Science and Engineering (Data Science)</option>
                <option selected="@(department == "Artificial Intelligence and Machine Learning")">Artificial Intelligence and Machine Learning</option>
                <option selected="@(department == "Artificial Intelligence (AI) and Data Science)")">Artificial Intelligence (AI) and Data Science</option>
                <option selected="@(department == "Computer Science and Engineering (IOT and Cyber Security with Block Chain Technology)")">Computer Science and Engineering (IOT and Cyber Security with Block Chain Technology)</option>
            </select>

            <br />

            <label>Faculty Name</label>
            <input type="text" name="FacultyName" value="@faculty" required />

            <br />

            <label>Upload Marks Excel</label>
            <input type="file" name="marksFile" required />

            <br />

            <label>Upload Mapping Excel</label>
            <input type="file" name="mappingFile" required />

            <br /><br />
            <!-- BUTTONS -->
            <button id="uploadBtn" type="submit" class="btn btn-primary">
                Upload Files
            </button>

            <a id="analyzeBtn"
                   asp-controller="Upload"
                   asp-action="Analyze"
                   class="btn btn-success"
                   style="pointer-events:none; opacity:0.5;">
                Analyze Results
            </a>

            <!-- SPINNER -->
            <span id="processingArea" class="spinner-area">
                <span class="spinner-border spinner-border-sm text-light"></span>
                <span style="margin-left:5px;">Processing analysis...</span>
            </span>

        </form>

    </div>

</div>

<script>
    document.getElementById("analyzeBtn").addEventListener("click", function() {

        document.getElementById("processingArea").style.display = "inline";

        this.innerText = "Processing...";
        this.style.pointerEvents = "none";
        this.style.opacity = "0.6";

    });
</script>