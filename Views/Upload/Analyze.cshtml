@using System.Text.Json
@model AcademicAnalytics.Models.AnalysisResult

@functions {
    public string GetIcon(string text, string type)
    {
        text = text.ToLower();

        if (type == "S") // Strength
        {
            if (text.Contains("strong")) return "💪";
            if (text.Contains("moderate")) return "📊";
            if (text.Contains("improvement")) return "📈";
            return "⭐";
        }

        if (type == "C") // Concern
        {
            if (text.Contains("low")) return "📉";
            if (text.Contains("weak")) return "⚠️";
            if (text.Contains("fail")) return "❌";
            return "🚨";
        }

        if (type == "O") // Observation
        {
            if (text.Contains("challenging")) return "🔥";
            if (text.Contains("majority")) return "📊";
            if (text.Contains("distribution")) return "🥧";
            return "👁️";
        }

        return "ℹ️";
    }
}

@functions {
    public string GetDifficultyColor(string level)
    {
        return level switch
        {
            "Easy" => "#27ae60",        // green
            "Moderate" => "#2980b9",    // blue
            "Difficult" => "#c0392b",   // red
            _ => "#000"
        };
    }
}

@functions {
    public string GetRowStyle(string level)
    {
        return level switch
        {
            "Easy" => "background-color:#27ae6020;",        // light green
            "Moderate" => "background-color:#2980b920;",    // light blue
            "Difficult" => "background-color:#c0392b20;",   // light red
            _ => ""
        };
    }

    public string GetTextColor(string level)
    {
        return level switch
        {
            "Easy" => "#27ae60",
            "Moderate" => "#2980b9",
            "Difficult" => "#c0392b",
            _ => "#000"
        };
    }
}

<div class="page-center">

    <!-- Background blobs -->
    <div class="blob blob1"></div>
    <div class="blob blob2"></div>
    <div class="blob blob3"></div>

    <div class="glass-card" style="max-width:1200px;">

        <!-- HEADER -->
        <div class="page-title">
            <h2>Academic Analytics Dashboard</h2>
            <p>Built by the Department of Information Technology to empower academic insights</p>
        </div>

        <!-- METADATA -->
        <div class="meta-bar" style="text-align:center; margin-bottom:20px;">
            <strong>Subject:</strong> @ViewBag.Subject |
            <strong>Semester:</strong> @ViewBag.Semester |
            <strong>Academic Year:</strong> @ViewBag.AcademicYear
            <br />
            <strong>Department:</strong> @ViewBag.Department |
            <strong>Faculty:</strong> @ViewBag.FacultyName
        </div>

        <!-- ================= INSIGHTS ================= -->
        <div class="section">
            <h3>Insights</h3>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px;margin-bottom:20px;">

            @{
                var strengths = new List<string>();
                var concerns = new List<string>();
                var observations = new List<string>();

                string current = "";

                foreach (var item in Model.Insights)
                {
                    if (item == "Strengths:") { current = "S"; continue; }
                    else if (item == "Concerns:") { current = "C"; continue; }
                    else if (item == "Key Observations:") { current = "O"; continue; }

                    if (current == "S") strengths.Add(item.Replace("• ", ""));
                    else if (current == "C") concerns.Add(item.Replace("• ", ""));
                    else if (current == "O") observations.Add(item.Replace("• ", ""));
                }
            }

            <!-- Strengths -->
            @if (strengths.Count > 0)
            {
                <div class="insight-card strength">
                    <h4 class="insight-title strength">🟢 Strengths</h4>
                    @foreach (var s in strengths)
                    {
                        <div style="margin-bottom:8px;">
                            @GetIcon(s, "S") @Html.Raw(s)
                        </div>
                    }
                </div>
            }

            <!-- Concerns -->
            @if (concerns.Count > 0)
            {
                <div class="insight-card concern">
                    <h4 class="insight-title concern">🔴 Concerns</h4>
                    @foreach (var c in concerns)
                    {
                        <div style="margin-bottom:8px;">
                            @GetIcon(c, "C") @Html.Raw(c)
                        </div>
                    }
                </div>
            }

            <!-- Observations -->
            @if (observations.Count > 0)
            {
                <div class="insight-card observation">
                    <h4 class="insight-title observation">🔵 Observations</h4>
                    @foreach (var o in observations)
                    {
                        <div style="margin-bottom:8px;">
                            @GetIcon(o, "O") @Html.Raw(o)
                        </div>
                    }
                </div>
            }

        </div>

        <!-- ================= TABLES ================= -->
        <div class="section">
        <h3>Question Difficulty Index</h3>
        </div>
        <div class="chart-container table-container">
            <table>
                <thead>
                    <tr>
                        <th>Question</th>
                        <th>Unit</th>
                        <th>Bloom Level</th>
                        <th>Average Score (%)</th>
                        <th>Difficulty Level (Based on the Avg Score)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var q in Model.DifficultyIndex)
                    {
                        var map = Model.Mapping.FirstOrDefault(m => m.Question == q.Key);

                        <tr style="
                            @GetRowStyle(Model.DifficultyLevel[q.Key]);
                            border-left: 4px solid @GetTextColor(Model.DifficultyLevel[q.Key]);
                            ">
                            <td>@q.Key.Replace(".", " ")</td>
                            <td>Unit @map?.Unit</td>
                            <td style="font-weight:600;">
                                @(map != null ? char.ToUpper(map.Bloom[0]) + map.Bloom.Substring(1).ToLower() : "")
                            </td>
                            <td style="font-weight:600; color:@GetTextColor(Model.DifficultyLevel[q.Key]);">
                                @Math.Round(q.Value, 2)%
                            </td>

                            <td style="font-weight:600; color:@GetTextColor(Model.DifficultyLevel[q.Key]);">
                                @Model.DifficultyLevel[q.Key]
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="section">
        <h3>Expected vs Actual Difficulty</h3>
        </div>
        <div class="chart-container table-container">
            <table>
                <thead>
                    <tr>
                        <th>Question</th>
                        <th>Unit</th>
                        <th>Given</th>
                        <th>Actual</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var q in Model.ExpectedDifficulty.Keys)
                    {
                        var expected = Model.ExpectedDifficulty[q];
                        var actual = Model.ActualDifficulty[q];
                        var mismatch = Model.DifficultyMismatch[q];

                        string status = !mismatch ? "OK"
                            : (expected == "Easy" && actual == "Difficult") ? "Too Difficult"
                            : (expected == "Difficult" && actual == "Easy") ? "Too Easy"
                            : "Mismatch";

                        var map = Model.Mapping.FirstOrDefault(m => m.Question == q);

                        <tr class="status-row @status.Replace(" ", "").ToLower()">
                            <td>@q.Replace(".", " ")</td>
                            <td>Unit @map?.Unit</td>
                            <td>@expected</td>
                            <td>@actual</td>
                            <td>
                                <span class="status-badge @status.Replace(" ", "").ToLower()">
                                    @status
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- ================= CHARTS ================= -->
        <div class="section">
        <h3>Difficulty Distribution</h3>
        </div>
        <div class="chart-container">
            <canvas id="difficultyChart" style="min-width:800px;"></canvas>
        </div>
        <br />
        <div class="alert alert-success">
            <strong>Paper Summary:</strong> @ViewBag.DifficultySummary
        </div>

        <!-- ================= RECOMMENDATIONS ================= -->
        <div class="section">
        <h3>Recommendations</h3>
        </div>
        <div class="glass-card" style="padding:20px;">
            @if (Model.Recommendations != null && Model.Recommendations.Count > 0)
            {
                @foreach (var rec in Model.Recommendations)
                {
                    var parts = rec.Split("|");
                    var text = parts[0];
                    var priority = parts.Length > 1 ? parts[1] : "Low";

                    <div class="recommendation-item @priority.ToLower()">
                        <span>👉 @text</span>
                        <span class="priority @priority.ToLower()">@priority</span>
                    </div>
                }
            }
            else
            {
                <strong>No major improvement areas detected.</strong>
            }
        </div>
        <br />
        <!-- ================= DASHBOARD ================= -->

        <div id="chartsSection" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:25px;">

            <div class="chart-container">
                <h4 style="text-align:center;">Unit Performance</h4>
                <canvas id="unitChart"></canvas>
            </div>

            <div class="chart-container">
                <h4 style="text-align:center;">CO Attainment</h4>
                <canvas id="coChart"></canvas>
            </div>

            <div class="chart-container">
                <h4 style="text-align:center;">Bloom Taxonomy</h4>
                <canvas id="bloomChart"></canvas>
            </div>

            <div class="chart-container" style="grid-column: 1 / -1;">
                <h4 style="text-align:center;">Question Performance</h4>

                <div class="chart-scroll">
                    @* <div class="fw-semibold mb-1">Performance Levels</div *@
                    <div class="d-flex justify-content-center gap-5 mb-3">

                        <div class="d-flex align-items-center">
                            <span style="width:12px;height:12px;background:#27ae60;display:inline-block;margin-right:6px;border-radius:2px;"></span>
                            Easy
                        </div>

                        <div class="d-flex align-items-center">
                            <span style="width:12px;height:12px;background:#2980b9;display:inline-block;margin-right:6px;border-radius:2px;"></span>
                            Moderate
                        </div>

                        <div class="d-flex align-items-center">
                            <span style="width:12px;height:12px;background:#c0392b;display:inline-block;margin-right:6px;border-radius:2px;"></span>
                            Difficult
                        </div>

                    </div>
                    <canvas id="questionChart"></canvas>
                </div>
            </div>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>

<script>
    Chart.register(ChartDataLabels);

    function createBarChart(canvasId, labels, data, label, xTitle, yTitle, colors, isPercentage = false) {
        const chart = new Chart(document.getElementById(canvasId), {
        type: 'bar',
        data: {
        labels: labels,
        datasets: [{
        label: label,
        data: new Array(data.length).fill(0),   // start from 0
        backgroundColor: colors,
        borderColor: "#2c3e50",
        borderWidth: 1.5,
        borderRadius: 6,
        barThickness: 40
        }]
        },
        options: {
        animation: {
        duration: 1000,
        easing: 'easeOutQuart'
        },
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
        legend: { display: false },
        datalabels: {
        anchor: 'end',
        align: 'start',
        offset: -2,
        color: function(context) {
        const value = context.dataset.data[context.dataIndex];
        return value < 10 ? '#000' : '#fff';
        },
        font: { weight: 'bold' },
        formatter: function(value) {
        return isPercentage ? value.toFixed(1) + "%" : value.toFixed(1);
        }
        }
        }
        }
        });
        setTimeout(() => {
        chart.data.datasets[0].data = data;
        chart.update();
        }, 50);
    }

    function loadCharts() {
        // =========================
        // BAR CHARTS
        // =========================

        setTimeout(() => {
            createBarChart(
            "unitChart",
            @Html.Raw(JsonSerializer.Serialize(Model.UnitChart.Labels)),
            @Html.Raw(JsonSerializer.Serialize(Model.UnitChart.Values)),
            "Unit Performance",
            '@Model.UnitChart.XAxisTitle',
            '@Model.UnitChart.YAxisTitle',
            "#3498db",
            true
            );
        }, 100);

        setTimeout(() => {
            createBarChart(
            "coChart",
            @Html.Raw(JsonSerializer.Serialize(Model.COChart.Labels)),
            @Html.Raw(JsonSerializer.Serialize(Model.COChart.Values)),
            "CO Attainment",
            '@Model.COChart.XAxisTitle',
            '@Model.COChart.YAxisTitle',
            "#2ecc71"
            );
        }, 250);

        setTimeout(() => {
            createBarChart(
            "questionChart",
            @Html.Raw(JsonSerializer.Serialize(Model.QuestionChart.Labels)),
            @Html.Raw(JsonSerializer.Serialize(Model.QuestionChart.Values)),
            "Question Performance",
            '@Model.QuestionChart.XAxisTitle',
            '@Model.QuestionChart.YAxisTitle',
            @Html.Raw(JsonSerializer.Serialize(Model.QuestionChart.Colors)),
            true
            );
        }, 400);

        // =========================
        // PIE CHART
        // =========================

        const bloomChart = new Chart(document.getElementById("bloomChart"), {
        type: 'pie',
        data: {
        labels: @Html.Raw(JsonSerializer.Serialize(Model.BloomChart.Labels)),
        datasets: [{
        data: [0,0,0,0,0,0],   // 👈 start empty
        backgroundColor: [
        "#3498db","#f06292","#f39c12","#8e44ad","#2ecc71","#e74c3c"
        ]
        }]
        },
        options: {
        animation: {
        duration: 1000
        },
        responsive: true,
        plugins: {
        datalabels: {
        color: '#fff',
        font: { weight: 'bold' },
        formatter: (value, ctx) => {
        let sum = ctx.dataset.data.reduce((a, b) => a + b, 0);
        return sum ? (value * 100 / sum).toFixed(1) + "%" : "";
        }
        }
        }
        }
        });

        // animate pie
        setTimeout(() => {
        bloomChart.data.datasets[0].data =
        @Html.Raw(JsonSerializer.Serialize(Model.BloomChart.Values));
        bloomChart.update();
        }, 80);
     }

        // =========================
        // DIFFICULTY CHART (FIXED)
        // =========================

        const difficultyLabels = @Html.Raw(JsonSerializer.Serialize(ViewBag.DifficultyLabels));
        const difficultyData = @Html.Raw(JsonSerializer.Serialize(ViewBag.DifficultyData));

        const difficultyColors = difficultyLabels.map(level => {
        if (level === "Easy") return "green";
        if (level === "Moderate") return "orange";
        if (level === "Difficult") return "red";
        });

        new Chart(document.getElementById("difficultyChart"), {
        type: 'bar',
        data: {
        labels: difficultyLabels,
        datasets: [{
        data: difficultyData,
        backgroundColor: difficultyColors,
        borderRadius: 6
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,

        plugins: {
        legend: { display: false },
        datalabels: {
        anchor: 'end',
        align: 'top',
        color: '#000',
        font: { weight: 'bold' },
        formatter: (value) => value
        }
        },

        scales: {
        x: {
        title: {
        display: true,
        text: 'Difficulty Level'
        }
        },
        y: {
        beginAtZero: true,
        suggestedMax: difficultyData && difficultyData.length ? Math.max(...difficultyData) + 1 : 5,  // 🔥 fixes missing label
        ticks: {
        stepSize: 1,
        precision: 0,
        callback: function(value) {
        return Number.isInteger(value) ? value : null;
        }
        },
        title: {
        display: true,
        text: "Number of Questions"
        }
        }
        }
        }
        });

    let chartsLoaded = false;

    const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
    if (entry.isIntersecting && !chartsLoaded) {

    const section = document.getElementById("chartsSection");

    // 👇 Step 1: trigger fade + slide
    section.classList.add("show");

    // 👇 Step 2: delay chart creation slightly
    setTimeout(() => {
    loadCharts();
    observer.disconnect();
    }, 300);

    chartsLoaded = true;
    }
    });
    }, {    
    threshold: 0.3
    });

    document.addEventListener("DOMContentLoaded", function () {
    const section = document.getElementById("chartsSection");
    if (section) {
    observer.observe(section);
    }
    });

    window.addEventListener("load", function () {
    const section = document.getElementById("chartsSection");
    if (section) {
    const rect = section.getBoundingClientRect();
    if (rect.top < window.innerHeight) {
    loadCharts();
    chartsLoaded = true;
    }
    }
    });
</script>