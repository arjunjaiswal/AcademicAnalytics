@using System.Text.Json
@model AcademicAnalytics.Models.AnalysisResult

<div style="text-align:center; margin-top:20px;">
    <h2>Academic Analytics Dashboard</h2>
    <p style="color:gray;">
        Initiative by the Department of Information Technology
    </p>
</div>

<br />

<p>
    <strong>Subject:</strong> @ViewBag.Subject
    &nbsp;&nbsp;|&nbsp;&nbsp;
    <strong>Semester:</strong> @ViewBag.Semester
    &nbsp;&nbsp;|&nbsp;&nbsp;
    <strong>Academic Year:</strong> @ViewBag.AcademicYear
</p>

<p>
    <strong>Department:</strong> @ViewBag.Department
    &nbsp;&nbsp;|&nbsp;&nbsp;
    <strong>Faculty:</strong> @ViewBag.FacultyName
</p>

<h3>Insights</h3>

<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px;margin-bottom:20px;">

    @{
        var strengths = new List<string>();
        var concerns = new List<string>();
        var observations = new List<string>();

        string current = "";

        foreach (var item in Model.Insights)
        {
            if (item == "Strengths:")
            {
                current = "S";
                continue;
            }
            else if (item == "Concerns:")
            {
                current = "C";
                continue;
            }
            else if (item == "Key Observations:")
            {
                current = "O";
                continue;
            }

            if (current == "S") strengths.Add(item.Replace("• ", ""));
            else if (current == "C") concerns.Add(item.Replace("• ", ""));
            else if (current == "O") observations.Add(item.Replace("• ", ""));
        }
    }

    <!-- 🟢 STRENGTHS -->
    @if (strengths.Count > 0)
    {
        <div style="background:#f0fff4;border-left:6px solid #27ae60;padding:15px;border-radius:8px;box-shadow:0 2px 6px rgba(0,0,0,0.1);">
            <h4 style="color:#27ae60;margin-bottom:10px;">🟢 Strengths</h4>

            @foreach (var s in strengths)
            {
                var text = s.ToLower();
                var icon = text.Contains("strong performance") ? "💪"
                         : text.Contains("above average") ? "📈"
                         : "🟢";

                <div style="margin-bottom:8px;line-height:1.5;">
                    @icon @Html.Raw(s)
                </div>
            }
        </div>
    }

    <!-- 🔴 CONCERNS -->
    @if (concerns.Count > 0)
    {
        <div style="background:#fff5f5;border-left:6px solid #e74c3c;padding:15px;border-radius:8px;box-shadow:0 2px 6px rgba(0,0,0,0.1);">
            <h4 style="color:#e74c3c;margin-bottom:10px;">🔴 Concerns</h4>

            @foreach (var c in concerns)
            {
                var text = c.ToLower();
                var icon = text.Contains("weakness") ? "⚠️" : "❌";

                <div style="margin-bottom:8px;line-height:1.5;">
                    @icon @Html.Raw(c)
                </div>
            }
        </div>
    }

    <!-- 🔵 OBSERVATIONS -->
    @if (observations.Count > 0)
    {
        <div style="background:#eef6ff;border-left:6px solid #3498db;padding:15px;border-radius:8px;box-shadow:0 2px 6px rgba(0,0,0,0.1);">
            <h4 style="color:#3498db;margin-bottom:10px;">🔵 Key Observations</h4>

            @foreach (var o in observations)
            {
                var text = o.ToLower();
                var icon = text.Contains("challenging") ? "🔥"
                         : text.Contains("majority") ? "📊"
                         : "📌";

                <div style="margin-bottom:8px;line-height:1.5;">
                    @icon @Html.Raw(o)
                </div>
            }
        </div>
    }

</div>

<h3>Question Difficulty Index</h3>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Question</th>
            <th>Unit</th>
            <th>Average Score (%)</th>
            <th>Difficulty Level</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var q in Model.DifficultyIndex)
        {
            <tr>
                @{
                    var map = Model.Mapping.FirstOrDefault(m => m.Question == q.Key);
                }

                <td>@q.Key.Replace(".", " ")</td>
                <td>Unit @map?.Unit</td>
                <td>@Math.Round(q.Value, 2)%</td>
                <td>@Model.DifficultyLevel[q.Key]</td>
            </tr>
        }
    </tbody>
</table>

<hr />

<h3>Expected vs Actual Difficulty</h3>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Question</th>
            <th>Unit</th>
            <th>Given (Faculty)</th>
            <th>Actual (Performance)</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var q in Model.ExpectedDifficulty.Keys)
        {
            var expected = Model.ExpectedDifficulty[q];
            var actual = Model.ActualDifficulty[q];
            var mismatch = Model.DifficultyMismatch[q];

            string status;

            if (!mismatch)
            {
                status = "OK";
            }
            else if (expected == "Easy" && actual == "Difficult")
            {
                status = "Too Difficult";
            }
            else if (expected == "Difficult" && actual == "Easy")
            {
                status = "Too Easy";
            }
            else
            {
                status = "Mismatch";
            }

            string rowStyle =
                status == "Too Difficult" ? "background-color:#ffcccc;" :
                status == "Too Easy" ? "background-color:#fff3cd;" :
                mismatch ? "background-color:#ffe6e6;" : "";

            <tr style="@rowStyle">
                @{
                    var map = Model.Mapping.FirstOrDefault(m => m.Question == q);
                }

                <td>@q.Replace(".", " ")</td>
                <td>Unit @map?.Unit</td>
                <td>@expected</td>
                <td>@actual</td>
                <td>@status</td>
            </tr>
        }
    </tbody>
</table>

<hr />

<h3>Question Difficulty Distribution (Actual)</h3>

<div style="width:450px;height:320px;margin:auto;">
    <canvas id="difficultyChart" style="background:#ffffff;"></canvas>
</div>

<hr />

<div style="margin-top:10px;padding:10px;background:#eef5ff;border-radius:6px;">
    <strong>Paper Difficulty Summary:</strong>
    @ViewBag.DifficultySummary
</div>

<hr />

<h3>Recommendations</h3>

@if (Model.Recommendations != null && Model.Recommendations.Count > 0)
{
    <div style="
        background:#fffbea;
        border-left:6px solid #f1c40f;
        padding:18px;
        border-radius:8px;
        box-shadow:0 2px 6px rgba(0,0,0,0.1);
        margin-bottom:20px;
        ">

        @* <h4 style="color:#2980b9;margin-bottom:12px;">💡 Teaching Recommendations</h4> *@
        <h4 style="color:#b7950b;margin-bottom:12px;">💡 Teaching Recommendations</h4>

        @foreach (var rec in Model.Recommendations)
        {
            var parts = rec.Split("|");
            var text = parts[0];
            var priority = parts.Length > 1 ? parts[1] : "Low";

            string color =
                priority == "High" ? "#e74c3c" :
                priority == "Medium" ? "#f39c12" :
                "#27ae60";

            <div style="display:flex;justify-content:space-between;align-items:center;
                margin-bottom:10px;font-size:15px;line-height:1.5;">

                <div>
                    👉 @text
                </div>

                <span style="
                    background:@color;
                    color:white;
                    padding:4px 10px;
                    border-radius:12px;
                    font-size:12px;
                    font-weight:bold;
                    ">
                    @priority
                </span>
            </div>
        }

    </div>
}
else
{
    <div style="background:#f0fff4;border-left:6px solid #27ae60;padding:15px;border-radius:8px;">
        <strong style="color:#27ae60;">No major improvement areas detected.</strong>
    </div>
}

<!-- DASHBOARD GRID -->

<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:25px;margin-top:20px;overflow-x:hidden;">

    <div style="background:white;padding:18px;border-radius:8px; box-shadow:0 2px 6px rgba(0,0,0,0.15);">
        <h4 style="text-align:center;">Unit Performance</h4>
        <canvas id="unitChart" height="260" style="background:#ffffff;"></canvas>
    </div>

    <div style="background:white;padding:18px;border-radius:8px; box-shadow:0 2px 6px rgba(0,0,0,0.15);">
        <h4 style="text-align:center;">CO Attainment</h4>
        <canvas id="coChart" height="260" style="background:#ffffff;"></canvas>
    </div>

    <div style="background:white;padding:18px;border-radius:8px; box-shadow:0 2px 6px rgba(0,0,0,0.15);">
        <h4 style="text-align:center;">Bloom Taxonomy Distribution</h4>
        <div style="width:300px;height:300px;margin:auto;">
            <canvas id="bloomChart" style="background:#ffffff;"></canvas>
        </div>
    </div>

    <div style="grid-column: 1 / -1;background:white;padding:18px;border-radius:8px; box-shadow:0 2px 6px rgba(0,0,0,0.15);">
        <h4 style="text-align:center;">Question Performance</h4>

        <div style="display:flex;justify-content:center;gap:20px;margin-bottom:10px;font-size:14px;">

            <div style="display:flex;align-items:center;gap:6px;">
                <span style="width:14px;height:14px;background:#27ae60;border-radius:3px;"></span>
                <span>High (&gt;75%)</span>
            </div>

            <div style="display:flex;align-items:center;gap:6px;">
                <span style="width:14px;height:14px;background:#2980b9;border-radius:3px;"></span>
                <span>Moderate (50–75%)</span>
            </div>

            <div style="display:flex;align-items:center;gap:6px;">
                <span style="width:14px;height:14px;background:#c0392b;border-radius:3px;"></span>
                <span>Low (&lt;50%)</span>
            </div>

        </div>

        <canvas id="questionChart" height="125" style="background:#ffffff;"></canvas>
    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>

<script>
    Chart.register(ChartDataLabels);

    function createBarChart(canvasId, labels, data, label, xTitle, yTitle, colors) {
    new Chart(document.getElementById(canvasId), {
    type: 'bar',
    data: {
    labels: labels,
    datasets: [{
    label: label,
    data: data,
    backgroundColor: colors,
    borderColor: "#2c3e50",
    borderWidth: 1.5,
    borderRadius: 6,
    barThickness: 40
    }]
    },
    options: {
    responsive: true,
    maintainAspectRatio: true,
    plugins: {
    legend: { display: false },

    datalabels: {
    anchor: 'end',
    align: 'top',
    color: '#000',
    font: { weight: 'bold' },
    formatter: function(value) {
    return value.toFixed(1);
    }
    }
    },
    scales: {
    x: {
    grid: { display: false },
    title: { display: true, text: xTitle }
    },
    y: {
    beginAtZero: true,
    suggestedMax: data && data.length ? Math.max(...data) + 1 : 5,   // 🔥 fix for label cutoff
    ticks: {
    stepSize: 1,
    precision: 0,
    callback: function(value) {
    return Number.isInteger(value) ? value : null;
    }
    },
    title: { display: true, text: yTitle }
    }
    }
    }
    });
    }

    // =========================
    // BAR CHARTS
    // =========================

    createBarChart(
    "unitChart",
    @Html.Raw(JsonSerializer.Serialize(Model.UnitChart.Labels)),
    @Html.Raw(JsonSerializer.Serialize(Model.UnitChart.Values)),
    "Unit Performance",
    '@Model.UnitChart.XAxisTitle',
    '@Model.UnitChart.YAxisTitle',
    "#3498db"
    );

    createBarChart(
    "coChart",
    @Html.Raw(JsonSerializer.Serialize(Model.COChart.Labels)),
    @Html.Raw(JsonSerializer.Serialize(Model.COChart.Values)),
    "CO Attainment",
    '@Model.COChart.XAxisTitle',
    '@Model.COChart.YAxisTitle',
    "#2ecc71"
    );

    createBarChart(
    "questionChart",
    @Html.Raw(JsonSerializer.Serialize(Model.QuestionChart.Labels)),
    @Html.Raw(JsonSerializer.Serialize(Model.QuestionChart.Values)),
    "Question Performance",
    '@Model.QuestionChart.XAxisTitle',
    '@Model.QuestionChart.YAxisTitle',
    @Html.Raw(JsonSerializer.Serialize(Model.QuestionChart.Colors))
    );

    // =========================
    // PIE CHART
    // =========================

    new Chart(document.getElementById("bloomChart"), {
    type: 'pie',
    data: {
    labels: @Html.Raw(JsonSerializer.Serialize(Model.BloomChart.Labels)),
    datasets: [{
    data: @Html.Raw(JsonSerializer.Serialize(Model.BloomChart.Values)),
    backgroundColor: [
    "#3498db",
    "#f06292",
    "#f39c12",
    "#8e44ad",
    "#2ecc71",
    "#e74c3c"
    ]
    }]
    },
    options: {
    responsive: true,
    plugins: {
    datalabels: {
    color: '#fff',
    font: { weight: 'bold' },
    formatter: (value, ctx) => {
    let sum = ctx.dataset.data.reduce((a, b) => a + b, 0);
    let percentage = (value * 100 / sum).toFixed(1) + "%";
    return percentage;
    }
    }
    }
    }
    });

    // =========================
    // DIFFICULTY CHART (FIXED)
    // =========================

    const difficultyLabels = @Html.Raw(JsonSerializer.Serialize(ViewBag.DifficultyLabels));
    const difficultyData = @Html.Raw(JsonSerializer.Serialize(ViewBag.DifficultyData));

    const difficultyColors = difficultyLabels.map(level => {
    if (level === "Easy") return "green";
    if (level === "Moderate") return "orange";
    if (level === "Difficult") return "red";
    });

    new Chart(document.getElementById("difficultyChart"), {
    type: 'bar',
    data: {
    labels: difficultyLabels,
    datasets: [{
    data: difficultyData,
    backgroundColor: difficultyColors,
    borderRadius: 6
    }]
    },
    options: {
    responsive: true,
    maintainAspectRatio: false,

    plugins: {
    legend: { display: false },
    datalabels: {
    anchor: 'end',
    align: 'top',
    color: '#000',
    font: { weight: 'bold' },
    formatter: (value) => value
    }
    },

    scales: {
    x: {
    title: {
    display: true,
    text: 'Difficulty Level'
    }
    },
    y: {
    beginAtZero: true,
    suggestedMax: difficultyData && difficultyData.length ? Math.max(...difficultyData) + 1 : 5,  // 🔥 fixes missing label
    ticks: {
    stepSize: 1,
    precision: 0,
    callback: function(value) {
    return Number.isInteger(value) ? value : null;
    }
    },
    title: {
    display: true,
    text: "Number of Questions"
    }
    }
    }
    }
    });
</script>